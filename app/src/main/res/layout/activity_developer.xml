<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_black"
    android:padding="32dp">

    <TextView
        android:id="@+id/tv_dev_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="// DEVELOPER //"
        android:fontFamily="monospace"
        android:textColor="@color/neon_purple"
        android:textSize="22sp"
        android:textStyle="bold"
        android:letterSpacing="0.3"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="120dp" />

    <TextView
        android:id="@+id/tv_dev_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Developer: Bayram"
        android:fontFamily="monospace"
        android:textColor="@color/neon_green"
        android:textSize="32sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tv_dev_label"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btn_github"
        android:layout_width="wrap_content"
        android:layout_height="52dp"
        android:text="[ github.com/x3nc1 ]"
        android:fontFamily="monospace"
        android:textColor="@color/bg_black"
        android:textSize="14sp"
        android:backgroundTint="@color/neon_purple"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/tv_dev_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
