<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="bg_black">#000000</color>
    <color name="bg_card">#0D0D0D</color>
    <color name="neon_green">#00FF41</color>
    <color name="neon_purple">#BF00FF</color>
    <color name="neon_purple_dark">#7B00CC</color>
    <color name="text_dim">#444444</color>
</resources>
